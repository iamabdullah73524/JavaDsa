class Solution {
    public String licenseKeyFormatting(String s, int k) {
       String str = s.toUpperCase().replace("-", "");
        int n=str.length();
        StringBuilder sb = new StringBuilder("");
        int count=0;

        for(int i=n-1 ; i>=0 ; i-- ){
            if(count==k){
                sb.append("-");
                count=0;
            }
          sb.append(str.charAt(i));
          count++;

        }
        return sb.reverse().toString();
    }
}
