class Solution {
    public boolean detectCapitalUse(String word) {
        int n=word.length();
        int count = count(word);

        if(count==n || count==0){
            return true;
        }
        else if(count==1 && Character.isUpperCase(word.charAt(0))){
            return true;
        }
        else {
            return false;
        }

    }
    public static int count(String s){
        int count=0;
        for(int i=0 ; i<s.length(); i++){
            char ch =s.charAt(i);
            if(Character.isUpperCase(ch)){
                count++;
            }
        }
        return count;
    }
}
