class Solution {
    static String URLify(String s) {
        // code here
        StringBuilder sb = new StringBuilder("");
        int n=s.length();
        
        for(int i=0 ; i<n ; i++){
            char ch = s.charAt(i);
            if(ch!=' '){
                sb.append(ch);
            }
            else{
                sb.append("%20");
            }
        }
        return sb.toString();
    }
}
