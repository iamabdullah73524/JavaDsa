class Solution {
    boolean isPalindrome(String s) {
        // code here
        int n=s.length();
        int i=0;
        int j=n-1;
        boolean flag = true;
        
        while(i<j){
            if(s.charAt(i)!=s.charAt(j)){
                return false;
            }
            i++;
            j--;
        }
        return flag;
    }
}
