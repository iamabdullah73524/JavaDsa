class Solution {
    public boolean canConstruct(String ransomNote, String magazine) {
        int[] freq = new int[26];

        for(int i=0 ; i<magazine.length(); i++){
            int curr= magazine.charAt(i)-'a';
            freq[curr]++;
        }

        for(int i=0 ; i<ransomNote.length(); i++){
            int curr=ransomNote.charAt(i)-'a';
            freq[curr]--;

            if(freq[curr]<0){
                return false;
            }
        }
        return true;
    }
}
