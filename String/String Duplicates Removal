class Solution {
    String removeDuplicates(String s) {
     
       StringBuilder sb = new StringBuilder("");
       int n=s.length();
       
       HashSet<Character> set = new HashSet<>();
       
       for(int i=0 ; i<n ; i++){
           char ch = s.charAt(i);
           if(!set.contains(ch)){
               set.add(ch);
               sb.append(ch);
           }
       }
       return sb.toString();
    }
}
