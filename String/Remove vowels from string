class Solution {
    String removeVowels(String s) {
        // code here
        int n=s.length();
        StringBuilder sb = new StringBuilder("");
        
        for(int i=0 ; i<n ; i++){
            char ch = s.charAt(i);
            if(ch!='a' && ch!='e' && ch!='i' && ch!='o' && ch!='u'){
                sb.append(ch);
            }
        }
        return sb.toString();
    }
}
