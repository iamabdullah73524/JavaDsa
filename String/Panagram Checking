class Solution {
    public static boolean checkPangram(String s) {
        // code here
        HashSet<Character> set = new HashSet<>();
        int n=s.length();
        
        
        for(int i=0 ; i<n ; i++){
            char ch = Character.toLowerCase(s.charAt(i));
            if(ch>='a' && ch<='z'){
                set.add(ch);
            }
        }
        
        if(set.size()==26){
            return true;
        }
        else{
            return false;
        }
    }
}
