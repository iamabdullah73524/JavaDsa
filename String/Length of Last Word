class Solution {
    public int lengthOfLastWord(String str) {  
        int count=0;
        int n= str.length();
        for(int i=0 ; i<n ; i++){
            if(str.charAt(i)!=' '){
                count++;
            }
            else if(str.charAt(i)==' '&& i!=n-1 && str.charAt(i+1)!=' '){
                count=0;
            }
        }
        return count;
    }   
}
