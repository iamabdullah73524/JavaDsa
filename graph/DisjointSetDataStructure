public class DisjointSetDataStructure{
    static int n=7;
    static int[] par = new int[7] ;
    static int[] rank= new int[7];

    public static void init(){
        for(int i=0 ; i<n ; i++){
            par[i]=i;
        }
    }

    public static int find(int x){
        if(par[x]==x){
            return x;
        }
        return par[x]= find(par[x]);

    }

    public static void union(int a,  int b){
        int parA= find(a);
        int parB = find(b);

        if(rank[parA]==rank[parB]){ //A ko b se jor denge ya B ko A se jor denge dono same rank ke hai ya B ko A se jor denge dono same rank ke hai
            par[parA]=parB;
            rank[parB]++;
        }
        else if(rank[parA]<rank[parB]){ // A ko B se jor denge
            par[parA]=parB;
        }
        else if(rank[parA]>rank[parB]){ // B ko A se jor denge
            par[parB]=parA;
        }
    }

    public static void main(String[] args) {
        init();
        System.out.println(find(1));
        System.out.println(find(3));
        union(1,3);
        System.out.println(find(3));
        System.out.println(find(1));
    }
}
