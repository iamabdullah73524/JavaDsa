class Solution {
    public int[] countOddEven(int[] arr) {
        // Code here
        int ecount=0;
        int oddcount=0;
        int n= arr.length;
         int[] ans = new int[2];
        
        for(int i=0 ; i<n ; i++){
            if(arr[i]%2==0){
                ecount++;
            }
            else{
                oddcount++;
            }
        }
      
        ans[0]=oddcount;
        ans[1]=ecount;
        
        return ans;
    }
}
