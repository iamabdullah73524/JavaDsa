import java.util.*;
class Solution {
    public ArrayList<Integer> prefSum(int[] arr) {
        // code here
        ArrayList<Integer> ans = new ArrayList<>();
        int n= arr.length;
        int sum=0;
        for(int i=0 ; i<n ; i++){
            sum=sum+arr[i];
            ans.add(sum);
        }
        
        return ans;
    }
}
