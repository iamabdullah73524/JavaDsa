import java.util.*;
class Solution {
    static int countDistinct(int arr[]) {
        // code here
        int n=arr.length;
        Arrays.sort(arr);
        int count=1;
        
        for(int i=0 ; i<n-1 ; i++){
            if(arr[i]!=arr[i+1]){
                count++;
            }
        }
        return count;
    }
}
