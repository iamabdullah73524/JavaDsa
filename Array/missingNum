import java.util.*;
class Solution {
	int missingNum(int arr[]) {
		// code here
		int n = arr.length;
		int lower = arr[0];
		int higher = arr[n - 1];
		
		
	HashSet<Integer> set = new HashSet<>();

        for(int num : arr){
            set.add(num);
        }
		
		
        for(int i = 1; i <= n+1 ; i++){
            if(!set.contains(i)){
                return i;
            }
        }
		return -1;
	}
}

//without hasset

class Solution {
    public int missingNumber(int[] nums) {
       int n=nums.length;
       int expectedsum=n*(n+1)/2; // nums is start from 0 and if number is start from expectesum=n+1*n+2/2
       int actualsum=0;

       for(int i=0 ; i<n ; i++){
        actualsum=actualsum+nums[i];
       }
       return expectedsum-actualsum;
    }
}







