//Time Complexity = O(n)
//Space Complexity= O(1)

import java.util.*;
class Solution {
    static ArrayList<Integer> subarraySum(int[] arr, int target) {
        // code here
        int n= arr.length;
        int si=0;
        int ei=0;
        ArrayList<Integer> ans = new ArrayList<>();
        
        int currsum=0;
        
        while(ei<n){
            currsum=currsum+arr[ei];
            
            while(currsum>target){
                currsum=currsum-arr[si];
                si=si+1;
            }
            
            if(currsum==target){
                ans.add(si+1);
                ans.add(ei+1);
                return ans;
            }
            ei++;
        }
        ans.add(-1);
        return ans;
    }
}
