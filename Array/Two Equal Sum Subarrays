class Solution {
    public boolean canSplit(int arr[]) {
        // code here
        int n=arr.length;
        int totalsum=0;
        
        for(int x=0 ; x<n ; x++){
            totalsum=totalsum+arr[x];
        }
        
        int prefixsum=0;
        for(int i=0 ; i<n ; i++){
            prefixsum=prefixsum+arr[i];
            if(prefixsum==totalsum - prefixsum){
                return true;
            }
        }
        
        return false;
    }
}
