class Solution {
    public int getSecondLargest(int[] arr) {
        // code here
        int mx = -1;
        int smx = 1;
        int n=arr.length;
        
        for(int i=0 ; i<n ; i++ ){
            if(arr[i]>mx){
                smx=mx;
                mx=arr[i];
            }
            else if(arr[i]<mx && arr[i]>smx){
                smx=arr[i];
            }
        }
        return smx;
    }
}
