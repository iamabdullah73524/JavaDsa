class Solution {
    public int[] rearrangeArray(int[] arr) {
        int[] ans = new int[arr.length];
        int n=arr.length;
        int pos=0;
        int neg=1;

        for(int i=0 ; i<n ; i++){
            if(arr[i]>0){
                ans[pos]=arr[i];
                pos=pos+2;
            }
            else{
                ans[neg]=arr[i];
                neg=neg+2;
            }
        }
        return ans;
    }
}
