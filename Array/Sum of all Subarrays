class Solution {
    public int subarraySum(int[] arr) {
        // code here
        //brute
        int n=arr.length;
        int sum=0;
        
        for(int i=0 ; i<n ; i++ ){
            int totail=arr[i]*(i+1)*(n-i);
            sum=sum+totail;
        }
        return sum;
    }
}

            


