import java.util.*;
class Solution {
    public int minDiff(int[] arr) {
        // code here
        int diff=0;
        int mindiff = Integer.MAX_VALUE;
        
        Arrays.sort(arr);
        
        for(int i=0 ; i<arr.length-1 ; i++){
            diff=Math.abs(arr[i]-arr[i+1]);
            if(diff<mindiff){
                mindiff=diff;
            }
        }
        return mindiff;
    }
}
