class Solution {
	
	public long totalFine(int date, int car[], int fine[]) {
		// code here
		long ans = 0;
		
		for (int i = 0 ; i<car.length ; i++) {
			if (date%2 == 0) {
				if (car[i]%2 != 0) {
					ans = ans + fine[i];
				}
			
			}
			else{
			    if(car[i]%2==0){
			        ans = ans+fine[i];
			    }
			}
		}
		return ans;
	}
}
