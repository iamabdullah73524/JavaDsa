        int n = a.length;

        for(int i=0 ; i<n ; i++){
            for(int j=i+1 ; j<n ; j++){
                if(a[i]==a[j]){
                    System.out.println("The element which Dulicate is found "+a[i]);
                }
            }
        }
    }
