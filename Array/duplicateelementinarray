//other method and Optimized TC(nlon) SC(1)
import java.util.*;
class Solution {
    public ArrayList<Integer> findDuplicates(int[] arr) {
        // code here
        Arrays.sort(arr);
        ArrayList<Integer> ans = new ArrayList<>();
        int n= arr.length;
        
        for(int i=0 ; i<n-1 ; i++){
            if(arr[i]==arr[i+1]){
                ans.add(arr[i]);
            }
        }
        return ans;
    }
}

//Using Hashmap
//Time Complexity  = O(n)
//Space Complexity = O(n)

import java.util.*;
class Solution {
    public ArrayList<Integer> findDuplicates(int[] arr) {
        // code here
       ArrayList<Integer> ans = new ArrayList<>();
       HashSet<Integer> set = new HashSet<>();
       
       for(int i=0 ; i<arr.length ; i++){
           if(set.contains(arr[i])){
               ans.add(arr[i]);
           }
           else{
               set.add(arr[i]);
           }
       }
       return ans;
    }
}
