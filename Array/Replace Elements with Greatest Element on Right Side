// it is also called Next Greater element
class Solution {
    public int[] replaceElements(int[] arr) {
        int n=arr.length;
        int[] rightmax = new int[n];
        rightmax[n-1]=-1;
        int max=arr[n-1];


        for(int i=n-2 ; i>=0 ; i--){
            rightmax[i]=max;
            if(arr[i]>max){
                max=arr[i];
            }
        }
        return rightmax;

    }
}
