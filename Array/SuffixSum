public class SuffixSum{
    public static void main(String[] args) {
        int[] arr = {10,20,10,5,15};
        int n=arr.length;
        int[] ans = new int[n];
        int sum=0;

        for(int i=n-1; i>=0 ; i--){
            sum=sum+arr[i];
            ans[i]=sum;
        }

        for(int i=0 ; i<n ; i++){
            System.out.print(ans[i]+" ");
        }


    }
}
